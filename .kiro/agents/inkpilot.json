{
  "name": "inkpilot",
  "description": "Agent for InkPilot — Personal AI assistant on AWS (Bedrock + Lambda + Telegram)",
  "prompt": "file://../prompts/inkpilot.md",
  "resources": ["file://README.md", "file://.kiro/steering/**/*.md"],
  "tools": [
    "read",
    "write",
    "shell",
    "grep",
    "glob",
    "web_search",
    "web_fetch",
    "introspect",
    "thinking",
    "code",
    "use_aws"
  ],
  "allowedTools": [
    "read",
    "shell",
    "grep",
    "glob",
    "web_search",
    "web_fetch",
    "introspect",
    "thinking",
    "code",
    "use_aws"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        ".kiro/**",
        ".github/**",
        "src/**",
        "test/**",
        "README.md",
        "CHANGELOG.md",
        "package.json",
        "package-lock.json",
        "tsconfig.json",
        "tsdown.config.ts",
        "vitest.config.ts",
        "biome.json",
        "lefthook.yml",
        "commitlint.config.ts",
        ".editorconfig",
        ".gitignore",
        ".npmpackagejsonlintrc.json",
        ".lockfile-lintrc.json",
        "cdk.json"
      ]
    },
    "shell": {
      "autoAllowReadonly": true,
      "deniedCommands": [".*git commit.*", ".*git push.*", ".*git tag .*", ".*npm publish.*"]
    }
  }
}
